{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "baseUrl": "src",
        "outDir": "dist",
        "strict": true,
        "alwaysStrict": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": true,
        "noImplicitReturns": false,
        "noImplicitThis": true,
        "noFallthroughCasesInSwitch": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "downlevelIteration": true,
        "paths": {
            "@nova/core/*": ["packages/core/*"],
            "@nova/listeners/*": ["packages/listeners/*"],
            "@nova/commands/*": ["packages/commands/*"],
            "@nova/typings/*": ["packages/typings/*"],
            "@nova/util/*": ["packages/util/*"]
        },
        "pretty": true
    },
    "include": ["typings/**/*", "src/**/*"]
}
