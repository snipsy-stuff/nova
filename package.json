{
    "name": "nova",
    "description": "nova a ''easy-to-use'' Discord bot.",
    "packageManager": "yarn@4.9.2",
    "dependencies": {
        "detritus-client": "0.17.0-beta.89",
        "luxon": "^3.7.2",
        "mongodb": "^7.1.0",
        "openai": "^6.18.0",
        "tsconfig-paths": "^4.2.0",
        "xml2js": "^0.6.2"
    },
    "scripts": {
        "rm": "rm -rf dist",
        "c": "clear",
        "pre-build": "yarn c && ./node_modules/.bin/tsc",
        "build": "yarn rm  && yarn pre-build",
        "dev": "yarn build && yarn start",
        "check-commands": "TS_NODE_BASEURL=./dist/ node -r  tsconfig-paths/register dist/index.js --check-commands",
        "start": "TS_NODE_BASEURL=./dist/ node -r  tsconfig-paths/register dist/index.js",
        "upload": "TS_NODE_BASEURL=./dist/ node -r  tsconfig-paths/register dist/index.js --upload-commands",
        "start:upload": "yarn build && yarn upload "
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/luxon": "^3.7.1",
        "@types/node": "^25.2.1",
        "@types/xml2js": "^0.4.14",
        "eslint": "^10.0.0",
        "prettier": "3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "8.54.0"
    }
}
